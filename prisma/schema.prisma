// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

//npx prisma generate
//npx prisma migrate dev
//npx prisma studio
//inserir no .env DATABASE_URL="file:./dev.db"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")//ignora
}

//tabelas do usuario
model usuarios {
  id         Int @id @default(autoincrement())
  name       String   
  nome       String   @unique
  email      String   @unique
  password   String
  profile_picture_url String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lojas      lojas[]
  avaliacoesLoja avaliacoesLoja[]
  comentariosAvaliacoes comentariosAvaliacoes[]
  avaliacoesProduto avaliacoesProduto[]
 
}
//tabela das lojas
model lojas {
  id         Int @id @default(autoincrement())

  usuarioId  Int @unique
  usuario    usuarios @relation(fields: [usuarioId], references: [id])
  
  nome       String
  descricao  String?
  logoUrl    String
  bannerUrl  String
  stickerUrl String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  avaliacoesLoja avaliacoesLoja[]
  produtos produtos[]
}

//tabela da avaliação da loja
model avaliacoesLoja {
  id         Int @id @default(autoincrement())

  usuarioId  Int  @unique
  usuario    usuarios @relation(fields: [usuarioId],  references: [id])

  lojaId     Int @unique
  loja       lojas @relation(fields: [lojaId], references: [id])

  nota       Int
  comentario String? 
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comentariosAvaliacoes comentariosAvaliacoes[]
}
//tabela com as avaliações dos produtos
model avaliacoesProduto {
  id         Int @id @default(autoincrement())

  usuarioId  Int @unique
  usuario    usuarios @relation(fields: [usuarioId], references: [id])
  
  productId  Int @unique
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comentariosAvaliacoes comentariosAvaliacoes[]
  produtos produtos[]


}
//tabela para os comentarios
model comentariosAvaliacoes {
  id         Int @id @default(autoincrement())

  usuarioId     Int @unique 
  usuario       usuarios @relation(fields: [usuarioId], references: [id])

  avaliacoesLojaId   Int @unique
  avaliacoesLoja     avaliacoesLoja @relation(fields: [avaliacoesLojaId], references: [id])

  avaliacoesProdutoId  Int @unique
  avaliacoesProduto    avaliacoesProduto @relation(fields: [avaliacoesProdutoId], references: [id])

  conteudo    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

}

//tabelas das categorias
model categorias {
  id         Int @id @default(autoincrement()) //link para parentcategory
  name       String 

  parentCategoryId Int? 
  parentCategory   categorias?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: Cascade)
  subCategories    categorias[] @relation("CategoryHierarchy")

  produtos    produtos[]
}

//tabela dos  produtos
model produtos {
  id         Int @id @default(autoincrement())

  lojaId     Int @unique 
  lojas       lojas @relation(fields: [lojaId], references: [id])
  
  categoriaId Int @unique
  categoria    categorias @relation(fields: [categoriaId], references: [id])

  name        String
  description String?
  preco       Float 
  estoque     Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  
  avaliacoesProduto avaliacoesProduto[]
  imagensProdutos imagensProdutos[]
  
}
//tabela das imagens
model imagensProdutos {
  id         Int @id @default(autoincrement())

  produtoId  Int @unique
  produto    produtos @relation(fields: [produtoId], references: [id])

  imageUrl   String
  ordem      Int
}